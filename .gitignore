# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Environment
.env
.venv/
venv/
env/
clnenv/

# Data — raw patient data is never committed
data/raw/*.csv
data/raw/*.xlsx
data/raw/*.parquet
data/processed/
data/models/
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/models/.gitkeep

# icd10_codes.csv is a public ICD-10 code/description reference
# table, not patient data, and is a hard runtime dependency for
# ICD10Mapper/HybridNERPipeline when data/processed/ isn't shipped
# (e.g. in the Docker image) — tracked despite the *.csv rule above.
!data/raw/icd10_codes.csv

# Database
*.db
*.sqlite
*.sqlite3

# Batch run output logs
*.log

# Notebooks
.ipynb_checkpoints/

# IDE
.vscode/settings.json
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Streamlit
.streamlit/secrets.toml
